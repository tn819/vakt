{
  "name": "@vakt/cli",
  "version": "0.4.0",
  "description": "Secure MCP runtime — unified config, policy enforcement, audit logging, registry verification",
  "bin": {
    "vakt": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/vakt",
    "test": "bats tests/",
    "test:unit": "bun test tests/unit/",
    "test:all": "bun test tests/unit/ && bats tests/",
    "knip": "knip",
    "lint": "eslint src/ --ignore-pattern '**/*.test.ts'",
    "lint:fix": "eslint src/ --ignore-pattern '**/*.test.ts' --fix",
    "lint:md": "markdownlint-cli2 \"docs/adr/**/*.md\"",
    "lint:adr": "bun run scripts/check-adrs.ts",
    "check:tool-enum": "bun run scripts/check-tool-enum.ts",
    "lint:docs": "bun run lint:md && bun run lint:adr",
    "pretest": "chmod +x src/vakt.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.0.0",
    "knip": "^5.88.0",
    "markdownlint-cli2": "^0.21.0",
    "semantic-release": "^24.0.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tn819/vakt.git"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-otlp-grpc": "^0.26.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "commander": "^14.0.3",
    "smol-toml": "^1.6.0",
    "zod": "^3.25.76"
  }
}
