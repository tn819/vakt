{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "docs", "scope": "README", "release": "patch" },
          { "type": "build", "scope": "deps", "release": "patch" },
          { "type": "chore", "release": "patch" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "agentctl-*.tar.gz",
            "label": "agentctl CLI"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json", "src/agentctl.sh"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ]
  ],
  "prepare": [
    {
      "path": "@semantic-release/exec",
      "cmd": "tar -czf agentctl-${nextRelease.version}.tar.gz --exclude='.git' --exclude='tests' --exclude='.github' --exclude='*.md' --exclude='.gitignore' ."
    },
    {
      "path": "@semantic-release/exec",
      "cmd": "sed -i 's/agentctl [0-9.]*/agentctl ${nextRelease.version}/' src/agentctl.sh"
    }
  ]
}
