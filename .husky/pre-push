BUN_BIN="${HOME}/.bun/bin"
if [ ! -d "$BUN_BIN" ]; then
  BUN_BIN=$(ls -d /Users/*/.bun/bin 2>/dev/null | head -1)
fi
export PATH="/usr/bin:/bin:/usr/local/bin:${BUN_BIN}:/opt/homebrew/bin:${PATH}"
export AGENTS_SECRETS_BACKEND="env"  # never trigger macOS keychain dialogs in hook subprocesses

REPO_ROOT="$(git rev-parse --show-toplevel)"

# If src/ changed, auto-refresh AGENTS.md and commit it if needed
if git diff --name-only HEAD @{u} 2>/dev/null | grep -q '^src/'; then
  bash "$REPO_ROOT/scripts/refresh-agents-md.sh"
  if ! git diff --quiet AGENTS.md; then
    git add "$REPO_ROOT/AGENTS.md"
    git commit -m "chore: refresh AGENTS.md architecture tree [pre-push]"
  fi
fi

# Full e2e suite — runs on every push
bats --recursive tests/
