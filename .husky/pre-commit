BUN_BIN="${HOME}/.bun/bin"
if [ ! -d "$BUN_BIN" ]; then
  BUN_BIN=$(ls -d /Users/*/.bun/bin 2>/dev/null | head -1)
fi
export PATH="/usr/bin:/bin:/usr/local/bin:${BUN_BIN}:/opt/homebrew/bin:${PATH}"
export AGENTS_SECRETS_BACKEND="env"  # never trigger macOS keychain dialogs in hook subprocesses

# Husky runs this with `sh -e`, but we need grep to be able to return 1 (no matches)
# without aborting the script. set +e disables exit-on-error for the whole script.
set +e

# Lint staged production TypeScript files (sonarjs + @typescript-eslint rules)
# Only lints files you're actually changing — pre-existing violations in unmodified
# files don't block commits. Run `bunx eslint src/` to see the full picture.
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep '^src/.*\.ts$' | grep -v '\.test\.ts$')
if [ -n "$STAGED_TS" ]; then
  # shellcheck disable=SC2086
  bunx eslint $STAGED_TS
  [ $? -ne 0 ] && exit 1
fi

# Fast unit tests (~40ms)
bun test src/ || exit 1

# Dead code / unused dep check
bun run knip || exit 1
